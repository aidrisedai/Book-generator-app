# Copy this file to ".env" and fill in your keys.

# Required — used by Claude to write and structure the story.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Required — used by OpenAI to illustrate each page (gpt-image-1).
# Get one at https://platform.openai.com/
OPENAI_API_KEY=

# Optional overrides (defaults shown).
# STORY_MODEL=claude-opus-4-8

# IMAGE_MODEL options:
#   gpt-image-1  (default, best quality — but your OpenAI org must be VERIFIED)
#   dall-e-3     (easier: works on any account with billing, no verification)
# If images fail with a "must be verified" error, switch to dall-e-3:
# IMAGE_MODEL=gpt-image-1

# IMAGE_SIZE=1024x1024
# IMAGE_QUALITY=medium
# PORT=3000
